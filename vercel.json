{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm run vercel:install",
  "buildCommand": "npm run vercel:build",
"outputDirectory": "dist",
  "functions": {
    "api/[...all].js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}